---
import * as m from '@/messages'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { getTotalStars } from '@/services/github'

const locale = Astro.locals.locale || 'en'
const brand = Astro.locals.runtimeConfig?.public?.brand || 'Capgo'
const totalStars = getTotalStars()

const products = [
  { href: getRelativeLocaleUrl(locale, 'live-update'), label: m.live_update({}, { locale }) },
  { href: getRelativeLocaleUrl(locale, 'native-build'), label: m.native_build({}, { locale }) },
  { href: getRelativeLocaleUrl(locale, 'plugins'), label: m.plugins({}, { locale }) },
  { href: getRelativeLocaleUrl(locale, 'integrations'), label: m.integrations_badge({}, { locale }) },
]

const solutions = [
  {
    title: m.solutions_by_team({}, { locale }),
    items: [
      { href: getRelativeLocaleUrl(locale, 'enterprise'), label: m.solutions_enterprise_short({}, { locale }) },
      { href: getRelativeLocaleUrl(locale, 'consulting'), label: m.consulting({}, { locale }) },
      { href: getRelativeLocaleUrl(locale, 'contributing'), label: m.contributing({}, { locale }) },
    ],
  },
  {
    title: m.solutions_by_industry({}, { locale }),
    items: [
      { href: getRelativeLocaleUrl(locale, 'app_mobile'), label: m.app_mobile({}, { locale }) },
      { href: getRelativeLocaleUrl(locale, 'ci_cd'), label: m.ci_cd_integration({}, { locale }) },
      { href: getRelativeLocaleUrl(locale, 'security'), label: m.security_txt({}, { locale }) },
    ],
  },
  {
    title: m.solutions_by_use_case({}, { locale }),
    items: [
      { href: getRelativeLocaleUrl(locale, 'alternatives'), label: m.alternatives({}, { locale }) },
      { href: getRelativeLocaleUrl(locale, 'trust'), label: m.trust({}, { locale }) },
      { href: getRelativeLocaleUrl(locale, 'skills'), label: 'Capacitor Skills' },
    ],
  },
]
---

<header class="relative py-2">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="relative flex items-center justify-between gap-6">
      <div class="flex shrink-0 items-center">
        <a href={getRelativeLocaleUrl(locale)} aria-label={m.capgo_home({}, { locale })} class="flex items-center pr-3 text-4xl font-medium font-prompt">
          <img class="h-18 w-auto pr-1" loading="eager" height="72" width="133" alt={`${brand} logo`} aria-label={`${brand} logo`} src="/capgo_logo.webp" />
        </a>
      </div>

      <div class="flex xl:hidden">
        <button type="button" class="text-white" aria-label={m.expand_menu({}, { locale })}>
          <svg class="h-7 w-7" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <div class="hidden xl:flex xl:flex-1 xl:items-center xl:gap-10">
        <nav class="flex items-center space-x-8">
          <a
            href={getRelativeLocaleUrl(locale, 'docs')}
            aria-label={m.docs({}, { locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.docs({}, { locale })}
          </a>

          <div class="group relative">
            <button
              type="button"
              class="flex items-center border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
              aria-label={m.products({}, { locale })}
            >
              {m.products({}, { locale })}
              <svg class="ml-1 h-4 w-4 transition-transform group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="invisible absolute left-0 z-50 w-56 pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
              <div class="rounded-lg border border-gray-700 bg-gray-800 py-2 shadow-xl">
                {
                  products.map((item) => (
                    <a href={item.href} class="block px-4 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white">
                      {item.label}
                    </a>
                  ))
                }
              </div>
            </div>
          </div>

          <div class="group relative">
            <button
              type="button"
              class="flex items-center border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
              aria-label={m.solutions({}, { locale })}
            >
              {m.solutions({}, { locale })}
              <svg class="ml-1 h-4 w-4 transition-transform group-hover:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="invisible absolute left-0 z-50 w-[640px] pt-2 opacity-0 transition-all duration-200 group-hover:visible group-hover:opacity-100">
              <div class="rounded-lg border border-gray-700 bg-gray-800 p-4 shadow-xl">
                <div class="grid grid-cols-3 gap-4">
                  {
                    solutions.map((section) => (
                      <div>
                        <p class="mb-2 px-2 text-xs font-semibold tracking-wider text-gray-500 uppercase">{section.title}</p>
                        {
                          section.items.map((item) => (
                            <a href={item.href} class="block rounded-lg px-2 py-2 text-sm text-gray-300 transition-colors hover:bg-gray-700 hover:text-white">
                              {item.label}
                            </a>
                          ))
                        }
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>

          <a
            href={getRelativeLocaleUrl(locale, 'enterprise')}
            aria-label={m.enterprise_title({}, { locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.enterprise_title({}, { locale })}
          </a>

          <a
            href={getRelativeLocaleUrl(locale, 'pricing')}
            aria-label={m.pricing({}, { locale })}
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.pricing({}, { locale })}
          </a>
        </nav>

        <div class="ml-auto flex items-center space-x-4">
          <a
            href={getRelativeLocaleUrl(locale, 'plugins')}
            aria-label={m.github_stars({}, { locale })}
            class="flex items-center gap-2 rounded-md bg-gray-800 px-3 py-1.5 text-sm font-medium text-gray-300 transition-colors hover:bg-gray-700"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill-rule="evenodd"
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                clip-rule="evenodd"
              />
            </svg>
            <span>{totalStars}+</span>
          </a>

          <a
            href="https://console.capgo.app/login/"
            aria-label={m.login({}, { locale })}
            target="_blank"
            class="border-b-2 border-transparent text-base font-medium transition-all duration-200 hover:border-blue-600 focus:border-blue-600"
          >
            {m.login({}, { locale })}
          </a>

          <a
            href={getRelativeLocaleUrl(locale, 'register')}
            target="_blank"
            aria-label={m.register({}, { locale })}
            class="rounded-xl border border-gray-300 bg-transparent px-5 py-2 text-base font-semibold leading-7 text-gray-300 transition-all duration-200 hover:bg-gray-500 hover:text-white focus:bg-gray-500 focus:text-white focus:outline-none focus:ring-2 focus:ring-gray-300 focus:ring-offset-2 font-pj"
            role="button"
          >
            {m.register({}, { locale })}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>
