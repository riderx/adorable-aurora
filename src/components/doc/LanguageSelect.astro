---
import * as m from '@/messages'
import { locales } from '@/services/locale'

const currentLocale = Astro.locals.locale
---

<div class="language-select">
  <span class="label">{m.language_label({}, { locale: currentLocale })}</span>
  <span class="value">{currentLocale.toUpperCase()}</span>
</div>

<script is:inline define:vars={{ locales, currentLocale }}>
  document.querySelectorAll('[data-lang-link]').forEach((node) => {
    node.addEventListener('click', () => {
      const locale = node.getAttribute('data-lang-link')
      if (!locale) return
      const pathname = window.location.pathname.replace(`/${currentLocale}/`, '/')
      window.location.href = locale === 'en' ? pathname : `/${locale}${pathname}`
    })
  })
</script>

<style>
  .language-select {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    font-size: var(--sl-text-sm);
    color: var(--sl-color-text);
    background: var(--sl-color-bg-nav);
  }

  .label {
    color: var(--sl-color-gray-3);
  }

  .value {
    font-weight: 600;
    color: var(--sl-color-white);
  }
</style>
