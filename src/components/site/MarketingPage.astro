---
interface Props {
  kicker: string
  title: string
  summary: string
  primaryHref?: string
  primaryLabel?: string
  secondaryHref?: string
  secondaryLabel?: string
}

const {
  kicker,
  title,
  summary,
  primaryHref = '/register/',
  primaryLabel = 'Start free',
  secondaryHref = '/docs/',
  secondaryLabel = 'Read docs',
} = Astro.props
---

<section class="relative overflow-hidden py-16 sm:py-20 lg:py-24">
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute inset-x-0 top-0 h-72 bg-linear-to-b from-sky-500/10 via-blue-500/5 to-transparent"></div>
    <div class="pulse-orb absolute -top-20 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-sky-400/15 blur-3xl"></div>
    <div class="drift-orb absolute right-0 bottom-0 h-80 w-80 rounded-full bg-emerald-400/10 blur-3xl"></div>
  </div>

  <div class="relative mx-auto flex max-w-7xl flex-col gap-14 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <p class="inline-flex items-center gap-2 rounded-full border border-sky-400/30 bg-sky-500/10 px-4 py-2 text-sm font-semibold tracking-[0.18em] text-sky-100 uppercase">
        <span class="inline-flex h-2 w-2 rounded-full bg-emerald-400"></span>
        {kicker}
      </p>
      <h1 class="mt-6 text-4xl font-bold leading-tight text-white sm:text-5xl lg:text-6xl font-pj">{title}</h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-8 text-gray-300 font-inter">{summary}</p>
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href={primaryHref} class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-blue-600/30 transition hover:bg-blue-700">
          {primaryLabel}
        </a>
        <a href={secondaryHref} class="inline-flex items-center justify-center rounded-xl border border-gray-600 px-8 py-4 text-base font-semibold text-gray-200 transition hover:border-gray-400 hover:bg-gray-800">
          {secondaryLabel}
        </a>
      </div>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="grid gap-8 md:grid-cols-2">
        <article class="rounded-3xl border border-white/10 bg-linear-to-br from-[#1b2028] to-[#10131a] p-8 shadow-2xl shadow-black/20 backdrop-blur-sm">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-500/15 ring-1 ring-blue-300/30">
            <svg class="h-6 w-6 text-blue-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M7 3v4m10-4v4M5 11h14v8H5z" />
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-white">Ship continuously</h2>
          <p class="mt-4 text-sm leading-7 text-gray-300">A landing-shaped page with the same dark surface treatment, long-form utility classes, and dense card layouts used in the real site.</p>
        </article>
        <article class="rounded-3xl border border-white/10 bg-[#161a22] p-8 shadow-2xl shadow-black/20">
          <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-emerald-500/15 ring-1 ring-emerald-300/30">
            <svg class="h-6 w-6 text-emerald-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M5 12l5 5L20 7" />
            </svg>
          </div>
          <h2 class="text-2xl font-semibold text-white">Protect production</h2>
          <p class="mt-4 text-sm leading-7 text-gray-300">The goal here is not design polish. It is to exercise Astro, Tailwind, and Starlight with a denser website route graph.</p>
        </article>
        <article class="rounded-3xl border border-blue-400/20 bg-blue-500/8 p-8">
          <p class="text-sm font-semibold tracking-[0.2em] text-blue-200 uppercase">Release rail</p>
          <div class="mt-6 space-y-4 text-sm text-gray-200">
            <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-black/20 px-4 py-3">
              <span>Development</span>
              <span class="rounded-full bg-sky-500/15 px-3 py-1 text-sky-200">Active</span>
            </div>
            <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-black/20 px-4 py-3">
              <span>Staging</span>
              <span class="rounded-full bg-amber-500/15 px-3 py-1 text-amber-200">Observed</span>
            </div>
            <div class="flex items-center justify-between rounded-2xl border border-white/10 bg-black/20 px-4 py-3">
              <span>Production</span>
              <span class="rounded-full bg-emerald-500/15 px-3 py-1 text-emerald-200">Healthy</span>
            </div>
          </div>
        </article>
        <article class="rounded-3xl border border-white/10 bg-[#151922] p-8">
          <p class="text-sm font-semibold tracking-[0.2em] text-gray-400 uppercase">Why this page exists</p>
          <ul class="mt-6 space-y-3 text-sm text-gray-200">
            <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-sky-400"></span>Flat route file shape similar to the production repo.</li>
            <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-emerald-400"></span>Large marketing sections and varied utility usage.</li>
            <li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-violet-400"></span>Scoped component CSS to mimic landing page style extraction.</li>
          </ul>
        </article>
      </div>

      <aside class="overflow-hidden rounded-[2rem] border border-white/10 bg-linear-to-br from-[#12161d] to-[#1a212c] p-8 shadow-2xl shadow-black/20">
        <p class="text-sm font-semibold tracking-[0.22em] text-gray-400 uppercase">Deployment timeline</p>
        <div class="mt-8 space-y-6">
          <div class="rounded-2xl border border-white/10 bg-black/20 p-5">
            <p class="text-xs font-semibold tracking-[0.18em] text-sky-200 uppercase">08:15 UTC</p>
            <p class="mt-2 text-lg font-semibold text-white">Bundle uploaded</p>
            <p class="mt-2 text-sm leading-7 text-gray-300">The reproduction includes dense side panels and bordered cards because the real app does the same across many pages.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/20 p-5">
            <p class="text-xs font-semibold tracking-[0.18em] text-emerald-200 uppercase">08:17 UTC</p>
            <p class="mt-2 text-lg font-semibold text-white">Validation passed</p>
            <p class="mt-2 text-sm leading-7 text-gray-300">That pushes more shared Tailwind utilities into the website CSS bundle where the Starlight leak appears in the real project.</p>
          </div>
          <div class="rounded-2xl border border-white/10 bg-black/20 p-5">
            <p class="text-xs font-semibold tracking-[0.18em] text-amber-200 uppercase">08:22 UTC</p>
            <p class="mt-2 text-lg font-semibold text-white">Global rollout</p>
            <p class="mt-2 text-sm leading-7 text-gray-300">If Astro starts attaching the Starlight reset chunk here too, the repro is finally matching the real failure mode.</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .pulse-orb {
    animation: pulse-orb 9s ease-in-out infinite;
  }

  .drift-orb {
    animation: drift-orb 12s ease-in-out infinite;
  }

  @keyframes pulse-orb {
    0%,
    100% {
      opacity: 0.35;
      transform: translate(-50%, 0) scale(1);
    }
    50% {
      opacity: 0.6;
      transform: translate(-50%, 0) scale(1.08);
    }
  }

  @keyframes drift-orb {
    0%,
    100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-18px, -14px);
    }
  }
</style>
