---
import Layout from '../layouts/Layout.astro'
---

<Layout>
  <main class="mx-auto flex min-h-screen max-w-5xl flex-col items-start justify-center gap-6 px-6 py-20 text-white">
    <p class="font-pj text-sm font-semibold tracking-[0.2em] text-sky-400 uppercase">Website 404</p>
    <h1 class="font-pj text-5xl font-semibold tracking-tight">Page not found</h1>
    <p class="max-w-2xl text-lg leading-8 text-gray-300">
      This custom project 404 matches the landing setup more closely than Starlight owning <code>/404</code>.
    </p>
    <a href="/" class="inline-flex w-fit items-center rounded-full bg-white px-5 py-3 text-sm font-medium text-gray-950 transition hover:bg-gray-200">
      Back home
    </a>
  </main>
</Layout>
