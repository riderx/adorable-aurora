---
import Layout from '../layouts/Layout.astro'
---

<Layout>
  <div class="space-y-6 text-slate-100">
    <div class="space-y-2">
      <p class="text-sm font-semibold tracking-[0.2em] text-sky-400 uppercase">Website Route</p>
      <h1 class="text-5xl font-semibold tracking-tight">`/` should not receive Starlight reset CSS</h1>
      <p class="max-w-2xl text-lg text-slate-300">
        The box below intentionally relies on browser default margins. If Starlight reset leaks here, the heading and paragraph margins collapse.
      </p>
    </div>

    <section class="rounded-3xl bg-white p-8 text-slate-900">
      <h1 id="native-heading">Plain H1 on the website route</h1>
      <p id="native-paragraph">This paragraph should keep browser default top and bottom margins.</p>
      <button id="native-button" type="button">Plain button</button>
      <p class="mt-6">
        <a href="/docs/">Open docs</a>
      </p>
    </section>
  </div>
</Layout>
